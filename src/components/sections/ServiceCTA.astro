---
import SectionContainer from "@components/layout/SectionContainer.astro";

interface Props {
  heading: string;
  description: string;
  ctaLabel: string;
}

const { heading, description, ctaLabel } = Astro.props;
---

<SectionContainer class="py-20 md:py-32">
  <div class="mx-auto max-w-3xl">
    <div
      class="border-primary/30 shadow-primary/10 relative overflow-hidden rounded-3xl border bg-linear-to-br from-zinc-900 via-zinc-900 to-black p-10 text-center shadow-2xl backdrop-blur-sm md:p-16"
    >
      {/* Efecto de brillo */}
      <div
        class="via-primary/5 absolute inset-0 bg-linear-to-r from-transparent to-transparent"
      >
      </div>

      <div class="relative z-10">
        <h2 class="mb-4 text-3xl font-bold text-white md:text-5xl">
          {heading}
        </h2>
        <p class="mx-auto mb-8 max-w-xl text-lg leading-relaxed text-zinc-300">
          {description}
        </p>
        <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="/contacto"
            class="bg-primary hover:shadow-primary/20 inline-flex w-full items-center justify-center gap-2 rounded-xl px-8 py-4 text-lg font-bold text-black transition-all duration-300 hover:scale-105 hover:shadow-2xl sm:w-auto"
          >
            {ctaLabel}
            <svg
              class="h-5 w-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </a>

          <a
            href="/servicios"
            class="border-primary hover:bg-primary/10 inline-flex w-full items-center justify-center gap-2 rounded-xl border-2 px-8 py-4 text-lg font-bold text-white transition-all duration-300 hover:scale-105 sm:w-auto"
          >
            Ver Otros Servicios
          </a>
        </div>

        <p class="mt-6 text-sm text-zinc-400">
          📱 Mandanos mensaje a través de cualquier red social
        </p>
      </div>
    </div>
  </div>
</SectionContainer>
