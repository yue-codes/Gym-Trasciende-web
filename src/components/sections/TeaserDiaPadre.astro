---
/**
 * TeaserDiaPadre.astro
 *
 * Banner compacto de la promo Día del Padre (junio 2026) para el home.
 * Lleva al usuario a /promociones donde ve los planes completos.
 *
 * Para eliminar del home: quitar <TeaserDiaPadre /> de
 * src/pages/index.astro (este componente no toca nada más).
 */

import SectionContainer from "@components/layout/SectionContainer.astro";
import ArrowAnimation from "@components/icons/ArrowAnimation.astro";
---

<SectionContainer class="py-10 md:py-12">
  <div class="mx-auto max-w-7xl">
    <a
      href="/promociones"
      class="group relative flex flex-col items-start gap-5 overflow-hidden rounded-2xl border border-dashed border-amber-400/40 bg-zinc-900/60 p-6 backdrop-blur-sm transition-all duration-300 hover:-translate-y-0.5 hover:border-amber-400/70 hover:bg-zinc-900/80 sm:flex-row sm:items-center sm:justify-between md:p-8"
      aria-label="Ver promo Día del Padre en la página de promociones"
    >
      {/* Decorativo: "20%" grande translúcido — refuerza el descuento */}
      <div
        class="pointer-events-none absolute top-0 right-6 overflow-hidden opacity-[0.04] select-none"
        aria-hidden="true"
      >
        <span
          class="leading-none font-black text-amber-400"
          style="font-size: 9rem;"
        >
          20%
        </span>
      </div>

      {/* Ícono + información */}
      <div class="flex items-center gap-4">
        {/* Ícono */}
        <div
          class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-amber-400/10 text-2xl transition-transform duration-300 group-hover:scale-110"
        >
          👨‍💪
        </div>

        {/* Texto */}
        <div>
          {/* Badges */}
          <div class="mb-1.5 flex flex-wrap items-center gap-2">
            <span
              class="rounded-full bg-amber-400 px-2.5 py-0.5 text-xs font-black text-black uppercase"
            >
              Todo Junio
            </span>
            <span
              class="rounded-full border border-amber-400/40 bg-amber-400/10 px-2.5 py-0.5 text-xs font-semibold text-amber-300 uppercase"
            >
              Día del Padre
            </span>
          </div>

          {/* Título */}
          <h3 class="text-lg font-black text-white">
            Papá este mes te toca a ti 💪
          </h3>

          {/* Descripción breve */}
          <p class="mt-0.5 text-sm text-zinc-400">
            <span class="font-bold text-white">20 % de descuento</span> en Pesas y
            Spinning solo para papás
          </p>
        </div>
      </div>

      {/* Flecha CTA */}
      <div
        class="flex shrink-0 items-center gap-2 text-sm font-semibold text-amber-400 transition-all duration-300 group-hover:gap-3"
      >
        <span>Ver la promo</span>
        <ArrowAnimation class="size-4" />
      </div>
    </a>
  </div>
</SectionContainer>
