---
/**
 * PromoEventoBote.astro
 *
 * Tarjeta del evento especial "El Bote Challenge" — 22 de junio 2026.
 * Diseño de dos columnas (desktop): video de Instagram a la izquierda,
 * detalles y countdown a la derecha. En móvil se apila verticalmente.
 *
 * Para eliminar este evento del sitio: quitar <PromoEventoBote /> de
 * src/pages/promociones.astro (este componente no toca nada más).
 */

import InstagramVideo from "@components/media/InstagramVideo.astro";
import CountdownTimer from "@components/ui/CountdownTimer";
import SectionContainer from "@components/layout/SectionContainer.astro";

// ═══════════════════════════════════════════════════════════════
//  REGLAS DEL CONCURSO
// ═══════════════════════════════════════════════════════════════
const reglas = [
  "Ven al gym el 22 de junio con tu bote de agua",
  "Nuestro equipo elige el más random o creativo",
  "El ganador recibe 50 % de descuento en su mensualidad",
  "Un solo ganador por evento",
];
---

{/* ═══════════════════════════════════════════════════════
    SECCIÓN — Evento Especial El Bote Challenge
    Borde punteado para diferenciarlo visualmente de las
    tarjetas estándar de descuento
    ═══════════════════════════════════════════════════════ */}

{/* Anchor de navegación — scroll-mt compensa la altura del header fijo */}
<div id="bote-challenge" class="scroll-mt-24"></div>

<SectionContainer class="py-14 md:py-20">
  <div class="mx-auto max-w-7xl">

    {/* Tarjeta principal con borde punteado */}
    <div
      class="relative overflow-hidden rounded-3xl border border-dashed border-purple-500/40 bg-zinc-900/60 p-8 backdrop-blur-sm md:p-12"
    >

      {/* Decorativo: "50%" gigante translúcido de fondo */}
      <div
        class="pointer-events-none absolute inset-0 flex select-none items-center justify-end overflow-hidden pr-4 opacity-[0.03]"
        aria-hidden="true"
      >
        <span
          class="font-black leading-none text-purple-400"
          style="font-size: clamp(10rem, 28vw, 22rem);"
        >
          50%
        </span>
      </div>

      {/* Badges de la tarjeta */}
      <div class="relative mb-6 flex flex-wrap items-center gap-3">
        <span
          class="rounded-full border border-purple-500/40 bg-purple-500/10 px-3 py-1 text-xs font-black tracking-widest text-purple-400 uppercase"
        >
          Evento Especial
        </span>
        <span
          class="rounded-full bg-purple-500 px-3 py-1 text-xs font-black tracking-widest text-white uppercase"
        >
          Solo 22 de Junio
        </span>
      </div>

      {/* Layout: columna única en móvil, dos columnas en desktop */}
      <div class="relative flex flex-col gap-10 lg:flex-row lg:items-center lg:gap-16">

        {/* ── Columna izquierda: video de Instagram ── */}
        <div class="flex shrink-0 justify-center lg:justify-start">
          <InstagramVideo
            postId="DZomVucON0-"
            thumbnailUrl="/img/thumbnails/22junio.webp"
            title="El Bote Challenge — Gym Trasciende"
          />
        </div>

        {/* ── Columna derecha: detalles del evento ── */}
        <div class="flex flex-col gap-6">

          {/* Eyebrow + título */}
          <div>
            <p class="mb-2 text-sm font-bold tracking-widest text-purple-400 uppercase">
              ¿Tienes un bote random? 🧴
            </p>
            <h2 class="text-4xl font-black leading-tight text-white md:text-5xl">
              El Bote
              <span class="text-purple-400">Challenge</span>
            </h2>
            <p class="mt-3 text-lg leading-relaxed text-zinc-300">
              Trae el bote de agua más random que tengas al gym el{" "}
              <span class="font-bold text-white">22 de junio</span>.
              El que más nos sorprenda gana{" "}
              <span class="font-black text-purple-400">50 % de descuento</span>{" "}
              en su mensualidad.
            </p>
          </div>

          {/* Reglas del concurso */}
          <ul class="space-y-3">
            {
              reglas.map((regla) => (
                <li class="flex items-start gap-3">
                  <svg
                    class="mt-0.5 h-4 w-4 shrink-0 text-purple-400"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                    aria-hidden="true"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  <span class="text-sm text-zinc-300">{regla}</span>
                </li>
              ))
            }
          </ul>

          {/* Countdown hasta el 22 de junio */}
          <div>
            <p
              class="mb-3 text-xs font-semibold tracking-widest text-purple-400 uppercase"
            >
              Faltan para el evento
            </p>
            <CountdownTimer client:load targetDate="2026-06-22T08:00:00" />
          </div>

          {/* CTA */}
          <a
            href="/contacto"
            class="inline-flex w-fit items-center gap-2 rounded-xl bg-purple-500 px-6 py-3.5 text-sm font-black text-white transition-all duration-300 hover:scale-105 hover:bg-purple-400"
          >
            Quiero participar
          </a>
        </div>
      </div>
    </div>
  </div>
</SectionContainer>
