---
/**
 * PromoEventoBote.astro
 *
 * Tarjeta del evento "El Bote Challenge" — 22 de junio 2026. COMPLETADO.
 * Diseño de dos columnas (desktop): video de Instagram a la izquierda,
 * detalles y resumen del resultado a la derecha. En móvil se apila verticalmente.
 */

import InstagramVideo from "@components/media/InstagramVideo.astro";
import SectionContainer from "@components/layout/SectionContainer.astro";

const logros = [
  "Participaron decenas de botes creativos y únicos",
  "Nuestro equipo eligió al ganador más random",
  "El ganador se llevó 50 % de descuento en su mensualidad",
  "¡El ambiente estuvo increíble!",
];
---

{/* ═══════════════════════════════════════════════════════
    SECCIÓN — Evento Completado: El Bote Challenge
    ═══════════════════════════════════════════════════════ */}

{/* Anchor de navegación */}
<div id="bote-challenge" class="scroll-mt-24"></div>

<SectionContainer class="py-14 md:py-20">
  <div class="mx-auto max-w-7xl">

    {/* Tarjeta principal */}
    <div
      class="relative overflow-hidden rounded-3xl border border-dashed border-emerald-500/40 bg-zinc-900/60 p-8 backdrop-blur-sm md:p-12"
    >

      {/* Decorativo: trofeo gigante translúcido de fondo */}
      <div
        class="pointer-events-none absolute inset-0 flex select-none items-center justify-end overflow-hidden pr-4 opacity-[0.03]"
        aria-hidden="true"
      >
        <span
          class="font-black leading-none text-emerald-400"
          style="font-size: clamp(10rem, 28vw, 22rem);"
        >
          🏆
        </span>
      </div>

      {/* Badges */}
      <div class="relative mb-6 flex flex-wrap items-center gap-3">
        <span
          class="rounded-full border border-emerald-500/40 bg-emerald-500/10 px-3 py-1 text-xs font-black tracking-widest text-emerald-400 uppercase"
        >
          Evento Especial
        </span>
        <span
          class="rounded-full bg-emerald-500 px-3 py-1 text-xs font-black tracking-widest text-white uppercase"
        >
          ✓ Completado — 22 de Junio
        </span>
      </div>

      {/* Layout: columna única en móvil, dos columnas en desktop */}
      <div class="relative flex flex-col gap-10 lg:flex-row lg:items-center lg:gap-16">

        {/* ── Columna izquierda: video de Instagram ── */}
        <div class="flex shrink-0 justify-center lg:justify-start">
          <InstagramVideo
            postId="DZomVucON0-"
            thumbnailUrl="/img/thumbnails/22junio.webp"
            title="El Bote Challenge — Gym Trasciende"
          />
        </div>

        {/* ── Columna derecha: resumen del éxito ── */}
        <div class="flex flex-col gap-6">

          {/* Eyebrow + título */}
          <div>
            <p class="mb-2 text-sm font-bold tracking-widest text-emerald-400 uppercase">
              ¡Un éxito rotundo! 🏆
            </p>
            <h2 class="text-4xl font-black leading-tight text-white md:text-5xl">
              El Bote
              <span class="text-emerald-400">Challenge</span>
            </h2>
            <p class="mt-3 text-lg leading-relaxed text-zinc-300">
              El reto del <span class="font-bold text-white">22 de junio</span> superó todas las expectativas.
              La comunidad respondió con toda la creatividad y el ganador se llevó{" "}
              <span class="font-black text-emerald-400">50 % de descuento</span>{" "}
              en su mensualidad. ¡Gracias a todos los que participaron!
            </p>
          </div>

          {/* Resumen de lo que pasó */}
          <ul class="space-y-3">
            {
              logros.map((logro) => (
                <li class="flex items-start gap-3">
                  <svg
                    class="mt-0.5 h-4 w-4 shrink-0 text-emerald-400"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                    aria-hidden="true"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  <span class="text-sm text-zinc-300">{logro}</span>
                </li>
              ))
            }
          </ul>

          {/* Banner de resultado */}
          <div class="rounded-2xl border border-emerald-500/30 bg-emerald-500/10 px-5 py-4">
            <p class="text-sm font-bold text-emerald-300">
              🎉 ¡El evento fue todo un éxito! Mantente al pendiente de las redes para los próximos retos.
            </p>
          </div>

          {/* CTA a redes sociales */}
          <a
            href="/contacto"
            class="inline-flex w-fit items-center gap-2 rounded-xl bg-emerald-500 px-6 py-3.5 text-sm font-black text-white transition-all duration-300 hover:scale-105 hover:bg-emerald-400"
          >
            Ver próximos eventos
          </a>
        </div>
      </div>
    </div>
  </div>
</SectionContainer>
