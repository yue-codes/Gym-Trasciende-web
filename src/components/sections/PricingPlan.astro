---
/**
 * PricingPlan - Wrapper Astro para el selector de precios
 *
 * Este componente usa Preact para la interactividad.
 * client:load = Se hidrata inmediatamente al cargar la página
 * client:visible = Se hidrata cuando entra en viewport (más eficiente)
 */

import SectionContainer from "@components/layout/SectionContainer.astro";
import Subtitle from "@components/ui/Subtitle.astro";
import PricingSelector from "@components/ui/PricingSelector";
import type { AreaId } from "../../data/pricing";

interface Props {
  allowedAreas?: AreaId[];
  defaultArea?: AreaId;
  showSelector?: boolean;
}

const { allowedAreas, defaultArea = "area2", showSelector } = Astro.props;
---

<SectionContainer
  id="precios"
  backgroundImage="linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.7)), url('/precios2.webp')"
  fixedBackground={true}
  class="py-12 lg:py-16"
>
  <!-- Radial glow sutil en primary para coherencia de cupón -->
  <div
    class="pointer-events-none absolute inset-0 opacity-20"
    style="background: radial-gradient(ellipse 80% 50% at 50% 60%, #d5fb00, transparent);"
  />

  <Subtitle>Sin letras chiquitas: Nuestros Precios</Subtitle>

  <div class="relative mt-8">
    <!--
      client:visible = Solo se hidrata cuando es visible (mejor rendimiento)
      Cambia a client:load si quieres que se hidrate inmediatamente
    -->
    <PricingSelector
      client:visible
      allowedAreas={allowedAreas}
      defaultArea={defaultArea}
      showSelector={showSelector}
    />
  </div>
</SectionContainer>

<style>
  /* Animación personalizada para las tarjetas */
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  :global(.animate-fade-in) {
    animation: fade-in 0.5s ease-out forwards;
    opacity: 0;
  }
</style>
