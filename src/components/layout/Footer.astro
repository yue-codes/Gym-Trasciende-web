---
import Facebook from "@components/icons/Facebook.astro";
import Instagram from "@components/icons/Instagram.astro";
import Tiktok from "@components/icons/Tiktok.astro";
---

<footer class="bg-gray-900">
  <div class="mx-auto max-w-5xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="flex justify-center">
      <img src="/logo2.svg" alt="Gym Trasciende Logo" class="h-20 w-auto" />
    </div>

    <p class="mx-auto mt-6 max-w-md text-center leading-relaxed text-gray-400">
      Donde la ambición se encuentra con la acción. Ofrecemos guía constante de
      mejor versión física.
    </p>

    <!-- Direcciones para SEO Local -->
    <div class="mt-6 flex flex-col items-center gap-2 text-center text-sm text-gray-400 sm:flex-row sm:justify-center sm:gap-8">
      <div>
        <p>📍 Guillermo Prieto Sur 45, La Estación</p>
        <p>Ocotlán de Morelos, Oaxaca</p>
      </div>
      <div class="hidden h-8 w-px bg-gray-700 sm:block"></div>
      <div>
        <p>📍 Cuauhtémoc 50, 1ra Secc</p>
        <p>San Antonino Castillo Velasco, Oaxaca</p>
      </div>
    </div>

    <ul class="mt-12 flex flex-wrap justify-center gap-6 md:gap-8 lg:gap-12">
      <li>
        <a
          class="text-white transition hover:text-white/75"
          href="/promociones"
        >
          Promociones
        </a>
      </li>
      <li>
        <a class="text-white transition hover:text-white/75" href="/contacto">
          Contacto
        </a>
      </li>

      <li>
        <a class="text-white transition hover:text-white/75" href="/servicios">
          Servicios
        </a>
      </li>

      <li>
        <a class="text-white transition hover:text-white/75" href="/nosotros">
          Nosotros
        </a>
      </li>

      <li>
        <a class="text-white transition hover:text-white/75" href="/reviews">
          reviews
        </a>
      </li>
    </ul>

    <div class="mt-12 flex justify-center gap-3">
      <a
        href="https://www.facebook.com/profile.php?id=61583792785523"
        target="_blank"
        rel="noopener noreferrer"
        class="border-primary flex h-10 w-10 items-center justify-center rounded-lg border-2 transition-all hover:scale-110 hover:shadow-lg"
      >
        <Facebook class="h-5 w-5 text-white" />
      </a>
      <a
        href="https://www.instagram.com/trasciendegym?igsh=MmJxaHRjM2w2cG1p"
        target="_blank"
        rel="noopener noreferrer"
        class="border-primary flex h-10 w-10 items-center justify-center rounded-lg border-2 transition-all hover:scale-110 hover:shadow-lg"
      >
        <Instagram class="h-5 w-5 text-white" />
      </a>
      <a
        href="https://www.tiktok.com/@trasciende.gym"
        target="_blank"
        rel="noopener noreferrer"
        class="border-primary flex h-10 w-10 items-center justify-center rounded-lg border-2 transition-all hover:scale-110 hover:shadow-lg"
      >
        <Tiktok class="h-5 w-5 text-white" />
      </a>
    </div>
  </div>
</footer>
