---
import SectionContainer from "@components/layout/SectionContainer.astro";
import Subtitle from "@components/ui/Subtitle.astro";
import ServiceBentoCard from "./ServiceBentoCard.astro";

// Agrega, reordena o elimina servicios aquí.
// gridClass controla la posición en el grid de 3 columnas (desktop).
// El primer item debe ser col-span-2 y el segundo col-start-3 row-span-2
// para mantener el layout bento — no mover esos dos sin revisar el grid completo.
// Al crear una página dedicada para Zumba o Cafetería, cambia su href y elimina locationBadge si aplica a ambas.
const services = [
  {
    href: "/servicios/pesas-fuerza",
    image: "/bento-info/bentofuerza.webp",
    title: "Área de Pesas y Fuerza",
    price: "Desde $110/Semanal",
    schedule: "L-V: 5am-10pm | S: 7am-9pm | D: 12pm-4pm",
    feature: "Entrenadores certificados • Rutinas personalizadas",
    gridClass: "aspect-[4/5] md:col-span-2 md:row-span-1 md:aspect-video",
  },
  {
    href: "/servicios/spinning",
    image: "/bento-info/bentospining.webp",
    title: "Clases de Spinning",
    price: "Desde $180/Semanal",
    schedule: "L-V: 7am-9am | L-V: 6pm-8pm",
    feature: "Para todos los niveles",
    gridClass: "aspect-[4/5] md:col-start-3 md:row-span-2",
  },
  {
    href: "/servicios/nutricion",
    image: "/nutri.webp",
    imageBg: "bg-linear-to-br from-[#2d3d10] via-[#4a6020] to-[#8fae3a]",
    imgClass:
      "h-full w-full object-cover object-top transition-transform duration-300 ease-in-out md:group-hover:scale-105",
    title: "Nutrición y Recuperación",
    price: "Descuento especial",
    schedule: "Asistencia en el gym",
    feature: "Completamente personalizado y profesional",
    gridClass: "aspect-[4/5]",
  },
  {
    href: "/servicios/zumba",
    image: "/bento-info/zumba1.jpg",
    title: "Clases de Zumba",
    price: "Desde $30/Visita",
    schedule: "L-V: 8am-9am | L-V: 6:30pm-7:30pm",
    feature: "Baila y quema calorías con música latina",
    gridClass: "aspect-[4/5]",
    locationBadge: "Sucursal San Antonino",
  },
  {
    href: "/contacto",
    image: "/gym-9.jpg",
    imageBg: "bg-linear-to-br from-[#1a1200] via-[#3d2d00] to-[#7a5c00]",
    imgClass:
      "h-full w-full object-cover object-center opacity-60 transition-transform duration-300 ease-in-out md:group-hover:scale-105",
    title: "Cafetería",
    price: "Próximamente",
    schedule: "En horario del gym",
    feature: "Snacks, bebidas y suplementos para tu entrenamiento",
    gridClass: "aspect-[4/5] md:col-span-2 md:aspect-video",
    locationBadge: "Ambas sucursales",
  },
  {
    href: "/servicios/area-adultos",
    image: "/bento-info/entrenadores.webp",
    title: "Área de Adultos",
    price: "Desde $140/Semanal",
    schedule: "L-V: 8am-12pm",
    feature: "Entrenadores profesionales • Todos los niveles",
    gridClass: "aspect-[4/5]",
  },
];
---

<SectionContainer id="servicios" class="py-16 md:py-20">
  <Subtitle>¿Qué ofrecemos?</Subtitle>
  <div class="grid grid-cols-1 gap-4 md:grid-cols-3 md:grid-rows-3 md:p-0">
    {
      services.map((service) => (
        <ServiceBentoCard
          {...service}
          transitionName={`title-${service.href.split("/").pop()}`}
        />
      ))
    }
  </div>
</SectionContainer>
