---
import Layout from "@layouts/Layout.astro";
import HeroClipped from "@components/sections/HeroClipped.astro";
import PricingPlan from "@components/sections/PricingPlan.astro";
import SectionContainer from "@components/layout/SectionContainer.astro";
import TrustMetrics from "@components/sections/TrustMetrics.astro";
import Subtitle from "@components/ui/Subtitle.astro";
import Gallery from "@components/sections/Gallery.astro";
import ScheduleSection from "@components/sections/ScheduleSection.astro";
import ArrowAnimation from "@components/icons/ArrowAnimation.astro";
import ButtonAnimation from "@components/icons/ButtonAnimation.astro";
import ServiceBento from "@components/services/ServiceBento.astro";
import MobileBottomNav from "@components/layout/MobileBottomNav.tsx";

// Horarios del gimnasio
const schedule = [
  { days: "Lunes a Viernes", hours: "5:00 AM - 10:00 PM" },
  { days: "Sábado", hours: "6:00 AM - 5:00 PM" },
  { days: "Domingo", hours: "12:00 PM - 4:00 PM" },
];

// Configuración de navegación móvil
const mobileNavItems = [
  {
    id: "servicios",
    label: "Servicios",
    href: "#servicios",
    icon: "grid" as const,
  },
  {
    id: "horarios",
    label: "Horarios",
    href: "#horarios",
    icon: "clock" as const,
  },
  { id: "precios", label: "Precios", href: "#precios", icon: "tag" as const },
  {
    id: "galeria",
    label: "Galería",
    href: "/#galeria",
    icon: "image" as const,
  },
  {
    id: "inscribirse",
    label: "Inscríbete",
    href: "/contacto",
    icon: "star" as const,
  },
];
---

<Layout
  title="Servicios | Gym Trasciende - Pesas, Spinning, Nutrición y Más"
  description="Explora los servicios de Trasciende Gym en Ocotlán: pesas libres, clases de spinning, nutrición y planes para adultos mayores. ¡Todo lo que necesitas aquí!"
  keywords="servicios gym, clases spinning, área de pesas, entrenamiento fuerza, nutrición deportiva, gym adultos mayores, entrenadores certificados"
  type="website"
>
  <!-- 1. Hero -->
  <HeroClipped
    img="/gym-9.jpg"
    alt="Gym Trasciende - Nuestros servicios profesionales"
    minHeight="min-h-screen"
    overlayOpacity="70"
  >
    <div class="mx-auto w-full max-w-7xl px-4">
      <div class="flex w-full flex-col gap-8">
        {/* Badge minimalista */}
        <div class="inline-flex items-center gap-2">
          <div class="bg-primary h-px w-12"></div>
          <span
            class="text-primary text-sm font-semibold tracking-widest uppercase"
          >
            Todos Nuestros Servicios
          </span>
        </div>

        {/* Título */}
        <h1
          class="text-secondary text-5xl leading-tight font-bold tracking-wide md:text-7xl lg:text-8xl"
        >
          Nuestros Servicios
        </h1>

        {/* Subtítulo */}
        <p class="text-secondary max-w-2xl text-lg leading-relaxed md:text-xl">
          Descubre todo lo que Trasciende Gym tiene para ti: pesas, spinning,
          nutrición y programas especiales. Entrenadores certificados y
          equipamiento de primera.
        </p>

        {/* CTAs con estilo consistente */}
        <div class="flex flex-col gap-4 sm:flex-row sm:gap-6">
          <a
            href="#servicios"
            class="group border-primary text-primary hover:bg-primary/50 inline-flex items-center justify-center gap-2 rounded-lg border-2 px-5 py-2.5 font-bold transition-all duration-300 hover:scale-105 active:scale-95"
          >
            <span class="text-base font-semibold">Ver Servicios</span>
            <ButtonAnimation
              width={24}
              height={24}
              class="transition-transform group-hover:scale-110"
            />
          </a>

          <a
            href="#horarios"
            class="group border-secondary text-secondary hover:bg-secondary/50 inline-flex items-center justify-center gap-2 rounded-lg border-2 px-5 py-2.5 font-bold transition-all duration-300 hover:scale-105 active:scale-95"
          >
            <span class="text-base font-semibold">Ver horarios</span>
            <ArrowAnimation class="size-5" />
          </a>
        </div>
      </div>
    </div>
  </HeroClipped>

  <!-- 3. Grid de Servicios (BentoInfo) -->
  <div id="servicios">
    <ServiceBento />
  </div>

  <div id="precios">
    <PricingPlan />
  </div>

  <!-- 4. Por qué elegirnos -->
  <SectionContainer class="py-16 md:py-20">
    <div class="mx-auto max-w-4xl">
      <Subtitle>¿Por qué elegir nuestros servicios?</Subtitle>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        <!-- Punto 1 -->
        <div class="flex gap-4">
          <div
            class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-emerald-500/20"
          >
            <svg
              class="h-6 w-6 text-emerald-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"
              ></path>
            </svg>
          </div>
          <div>
            <h3 class="mb-2 text-lg font-bold text-white">
              Entrenadores con experiencia
            </h3>
            <p class="text-sm text-gray-300">
              Profesionales con años de experiencia en distintas especialidades
              como fuerza, cardio, nutrición y prevención de lesiones
            </p>
          </div>
        </div>

        <!-- Punto 2 -->
        <div class="flex gap-4">
          <div
            class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-teal-500/20"
          >
            <svg
              class="h-6 w-6 text-teal-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <div>
            <h3 class="mb-2 text-lg font-bold text-white">
              Equipamiento de Primera
            </h3>
            <p class="text-sm text-gray-300">
              Máquinas de última generación y mantenimiento constante
            </p>
          </div>
        </div>

        <!-- Punto 3 -->
        <div class="flex gap-4">
          <div
            class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-cyan-500/20"
          >
            <svg
              class="h-6 w-6 text-cyan-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
              ></path>
            </svg>
          </div>
          <div>
            <h3 class="mb-2 text-lg font-bold text-white">
              Ambiente Inclusivo
            </h3>
            <p class="text-sm text-gray-300">
              Programas para todos los niveles, edades y capacidades
            </p>
          </div>
        </div>

        <!-- Punto 4 -->
        <div class="flex gap-4">
          <div
            class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-emerald-400/20"
          >
            <svg
              class="h-6 w-6 text-emerald-300"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
              ></path>
            </svg>
          </div>
          <div>
            <h3 class="mb-2 text-lg font-bold text-white">Seguridad Primero</h3>
            <p class="text-sm text-gray-300">
              Protocolos estrictos y supervisión constante para tu bienestar
            </p>
          </div>
        </div>
      </div>
    </div>
  </SectionContainer>

  <SectionContainer id="horarios" class="py-16 md:py-20">
    <div class="mx-auto max-w-2xl">
      <ScheduleSection schedule={schedule} />
    </div>
  </SectionContainer>

  <!-- 5. Métricas -->
  <TrustMetrics />

  <!-- 6. CTA Final -->
  <SectionContainer class="py-20 md:py-24">
    <div
      class="mx-auto max-w-4xl rounded-2xl border border-emerald-500/30 bg-linear-to-br from-gray-900/80 to-gray-800/80 p-8 text-center backdrop-blur-sm md:p-12"
    >
      <h2 class="text-secondary mb-4 text-3xl font-bold md:text-4xl">
        ¡Únete a nosotros!
      </h2>
      <p class="text-secondary mx-auto mb-8 max-w-2xl text-lg leading-relaxed">
        Ven a conocernos y elige el plan que mejor se adapte a tus objetivos. Tu
        camino hacia una vida más saludable comienza aquí, en el corazón de
        Ocotlán.
      </p>

      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="/contacto"
          class="bg-primary hover:bg-secondary inline-flex w-full items-center justify-center gap-2 rounded-lg px-8 py-4 text-lg font-bold text-black transition-all duration-300 hover:scale-105 sm:w-auto"
        >
          Agenda tu Visita
          <svg
            class="h-5 w-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
        <a
          href="/promociones"
          class="inline-flex w-full items-center justify-center gap-2 rounded-lg border-2 border-emerald-500 px-8 py-4 text-lg font-bold text-white transition-all duration-300 hover:scale-105 hover:bg-emerald-500/10 sm:w-auto"
        >
          Ver Promociones especiales!
        </a>
      </div>
    </div>
  </SectionContainer>
  <Gallery />
  <MobileBottomNav
    client:load
    items={mobileNavItems}
    hideOnScroll={false}
    vibration={true}
  />
</Layout>
