  },
  {
    id: 2,
    servicio: "Clases de Spinning",
    subtitulo: "Instructor certificado incluido",
    precioOriginal: "$500",
    precioPromo: "$400",   // $500 × 0.80
    ahorro: "$100",        // $500 × 0.20
    icon: "🚴‍♂️",
    imagen: "/bento-info/bentospining.webp",
    highlight: true,
    features: [
      "Cupo limitado garantizado",
      "Lun–Vie 6am–7am / 7am–8am",
      "Lun–Vie 6pm–7pm / 7pm–8pm",
      "Instructor certificado",
      "Técnica y postura incluidas",
    ],
  },
];

// ═══════════════════════════════════════════════════════════════
//  CONDICIONES — Datos para el banner informativo
// ═══════════════════════════════════════════════════════════════
const condiciones = [
  {
    emoji: "📋",
    texto: "Muestra una",
    destacado: "foto con tu hij@",
  },
  {
    emoji: "📅",
    texto: "Válido del",
    destacado: "1 al 30 de junio",
  },
  {
    emoji: "👨‍💪",
    texto: "Solo para",
    destacado: "papás",
  },
];

// ═══════════════════════════════════════════════════════════════
//  PASOS — Cómo canjear el descuento de Día del Padre
// ═══════════════════════════════════════════════════════════════
const pasos = [
  {
    numero: 1,
    titulo: "Visítanos o escríbenos",
    descripcion:
      "Acércate al gym o contáctanos por redes sociales durante junio. Te atendemos con gusto.",
  },
  {
    numero: 2,
    titulo: "Acredita que eres papá",
    descripcion:
      "Muéstranos una foto tuya con tu hijo o hija y listo — con eso aplicamos el descuento.",
  },
  {
    numero: 3,
    titulo: "Activa tu 20 % off",
    descripcion:
      "El descuento se aplica directo en tu mensualidad de Pesas o Spinning. ¡Así de fácil, papá!",
  },
];

// ═══════════════════════════════════════════════════════════════
//  PROMOCIONES PERMANENTES — Sin fecha límite
// ═══════════════════════════════════════════════════════════════
const promosPermanentes = [
  {
    id: 1,
    icon: "🎁",
    titulo: "Inscripción Gratis",
    descripcion:
      "Sin costo de inscripción todo el año para cualquier plan. Sin letra pequeña, solo pagas tu mensualidad.",
    badge: "Todo el Año",
    detalle: "¡Ahorras $200!",
  },
  {
    id: 2,
    icon: "🎂",
    titulo: "Cumpleaños 10 % Off",
    descripcion:
      "Descuento del 10 % en tu mensualidad durante todo tu mes de cumpleaños. Presenta identificación oficial y disfruta.",
    badge: "Especial",
    detalle: "Cada año, tu mes",
  },
];

// ═══════════════════════════════════════════════════════════════
//  FAQ — Preguntas frecuentes sobre la promo de Día del Padre
// ═══════════════════════════════════════════════════════════════
const faqItems = [
  {
    question: "¿Quiénes pueden aprovechar esta promo?",
    answer:
      "Es exclusiva para papás. Solo necesitas mostrar una foto tuya con tu hijo o hija — con eso acreditamos que eres papá y aplicamos el descuento.",
  },
  {
    question: "¿Aplica para nuevas inscripciones y renovaciones?",
    answer:
      "Sí, el 20 % de descuento aplica tanto si te inscribes por primera vez como si eres miembro vigente que renueva su mensualidad durante el mes de junio.",
  },
  {
    question: "¿Puedo combinar esta promo con el descuento de cumpleaños?",
    answer:
      "Las promociones temporales no son acumulables entre sí. Sin embargo, la inscripción siempre es gratis sin importar el plan que elijas.",
  },
  {
    question: "¿Hasta cuándo está disponible?",
    answer:
      "La promo de Día del Padre está disponible del 1 al 30 de junio de 2026. Debes inscribirte o renovar dentro de ese período para aprovechar el precio especial.",
  },
  {
    question: "¿Puedo elegir entre Pesas y Spinning?",
    answer:
      "Sí, el 20 % aplica en la mensualidad de Pesas ($380 → $304, ahorras $76) o de Spinning ($500 → $400, ahorras $100). Elige el área que más se ajuste a tus metas.",
  },
  {
    question: "¿Qué incluye la mensualidad de Pesas?",
    answer:
      "Incluye acceso completo al área de fuerza y pesas, asesoría personalizada en rutinas y horarios Lun–Vie 5am–10pm, Sáb 6am–5pm, Dom 12pm–4pm.",
  },
  {
    question: "¿Qué incluye la mensualidad de Spinning?",
    answer:
      "Incluye acceso a todas las clases de Spinning con instructor certificado, en los horarios Lun–Vie 6am–7am, 7am–8am, 6pm–7pm y 7pm–8pm. Cupo limitado.",
  },
];

// ═══════════════════════════════════════════════════════════════
//  NAVEGACIÓN MÓVIL INFERIOR
// ═══════════════════════════════════════════════════════════════
const mobileNavItems = [
  { id: "planes-papa",  label: "Planes",     href: "#planes-papa",             icon: "clock" as const },
  { id: "permanentes",  label: "Siempre",    href: "#promociones-permanentes", icon: "tag"   as const },
  { id: "faq",          label: "FAQ",        href: "#faq",                     icon: "grid"  as const },
  { id: "inscribirse",  label: "Inscríbete", href: "/contacto",                icon: "star"  as const },
];
---

<Layout
  title="Promo Día del Padre Junio 2026 | Gym Trasciende — 20% Descuento Pesas y Spinning"
  description="Promo Día del Padre en Gym Trasciende Ocotlán. 20% de descuento en mensualidades de Pesas ($304) y Spinning ($400) durante todo junio 2026. Solo para papás con identificación."
  keywords="promo día del padre gym ocotlán, descuento papás junio 2026, pesas descuento ocotlán, spinning precio especial papás, gym trasciende junio, mensualidad gym papá"
  type="website"
>

  {/* ═══════════════════════════════════════════════════════
      SECCIÓN 1 — HERO
      Fondo: /imagenfondo5.webp con overlays oscuros
      Decorativo: "20%" gigante en el fondo (muy translúcido)
      Contenido: badge dorado, título + slogan, precios rápidos, CTAs
      ═══════════════════════════════════════════════════════ */}
  <section
    class="bg-background relative min-h-screen overflow-hidden"
    aria-label="Promo Día del Padre Junio 2026"
  >

    {/* Imagen de fondo del gym */}
    <img
      src="/imagenfondo5.webp"
      alt=""
      class="absolute inset-0 h-full w-full object-cover object-center"
      loading="eager"
      aria-hidden="true"
    />

    {/* Mobile: overlay sólido oscuro desde abajo */}
    <div class="from-background/97 via-background/85 absolute inset-0 bg-linear-to-t to-background/40 lg:hidden">
    </div>

    {/* Desktop: gradiente de izquierda (oscuro) a derecha (transparente) */}
    <div class="from-background via-background/90 absolute inset-0 hidden bg-linear-to-r to-transparent lg:block">
    </div>

    {/* Fade inferior suave en ambos breakpoints */}
    <div class="from-background absolute inset-x-0 bottom-0 h-48 bg-linear-to-t to-transparent">
    </div>

    {/* Decorativo: "20%" enorme de fondo — refuerza visualmente el descuento */}
    <div
      class="pointer-events-none absolute inset-0 flex select-none items-center justify-end overflow-hidden pr-4 opacity-[0.035] lg:pr-12"
      aria-hidden="true"
    >
      <span
        class="text-primary font-black leading-none"
        style="font-size: clamp(12rem, 32vw, 26rem);"
      >
        20%
      </span>
    </div>

    {/* Contenido centrado verticalmente */}
    <div class="relative z-10 flex min-h-screen items-center">
      <div class="mx-auto w-full max-w-7xl px-4 py-28 lg:pt-36 lg:pb-16">
        <div class="flex max-w-2xl flex-col gap-7">

          {/* Badge dorado — evoca el Día del Padre */}
          <div class="inline-flex items-center gap-3">
            <div class="h-px w-10 animate-pulse bg-amber-400"></div>
            <span
              class="rounded-full border border-amber-400/40 bg-amber-400/10 px-4 py-1.5 text-xs font-semibold tracking-widest text-amber-300 uppercase"
            >
              Día del Padre · Junio 2026
            </span>
          </div>

          {/* Título principal */}
          <h1
            class="text-5xl leading-[1.05] font-black tracking-tight text-white md:text-7xl lg:text-8xl"
          >
            Papá este mes
            <span
              class="from-primary to-primary/60 block bg-linear-to-r bg-clip-text text-transparent"
            >
              te toca a ti.
            </span>
          </h1>

          {/* Subtítulo */}
          <p class="max-w-xl text-lg leading-relaxed text-zinc-300 md:text-xl">
            <span class="text-primary font-bold">20 % de descuento</span> en mensualidades
            de{" "}
            <span class="font-semibold text-white">Pesas</span> y{" "}
            <span class="font-semibold text-white">Spinning</span>.
            Solo durante junio, solo para papás.
          </p>

          {/* Precios rápidos — vista previa del ahorro antes de bajar */}
          <div class="flex flex-wrap gap-3">

            {/* Precio Pesas */}
            <div
              class="rounded-xl border border-zinc-700 bg-zinc-900/70 px-4 py-3 backdrop-blur-sm"
            >
              <p class="text-xs font-medium tracking-wider text-zinc-500 uppercase">
                Pesas
              </p>
              <div class="mt-1 flex items-baseline gap-2">
                <span class="text-sm text-zinc-500 line-through">$380</span>
                <span class="text-primary text-xl font-black">$304</span>
              </div>
            </div>

            {/* Precio Spinning */}
            <div
              class="rounded-xl border border-zinc-700 bg-zinc-900/70 px-4 py-3 backdrop-blur-sm"
            >
              <p class="text-xs font-medium tracking-wider text-zinc-500 uppercase">
                Spinning
              </p>
              <div class="mt-1 flex items-baseline gap-2">
                <span class="text-sm text-zinc-500 line-through">$500</span>
                <span class="text-primary text-xl font-black">$400</span>
              </div>
            </div>

            {/* Pill de inscripción gratis */}
            <div
              class="flex items-center rounded-xl border border-zinc-700 bg-zinc-900/70 px-4 py-3 backdrop-blur-sm"
            >
              <p class="text-xs font-semibold text-zinc-400">
                🎁 Inscripción <span class="text-white">gratis</span>
              </p>
            </div>
          </div>

          {/* CTAs */}
          <div class="flex flex-col gap-4 pt-2 sm:flex-row">

            {/* CTA principal — baja a las tarjetas */}
            <a
              href="#planes-papa"
              class="group border-primary text-primary hover:bg-primary/20 inline-flex items-center justify-center gap-2 rounded-xl border-2 px-6 py-3.5 font-bold transition-all duration-300 hover:scale-105 active:scale-95"
            >
              <span class="text-base font-semibold">Ver Planes</span>
              <ButtonAnimation
                width={22}
                height={22}
                class="transition-transform group-hover:scale-110"
              />
            </a>

            {/* CTA secundario — ir a contacto */}
            <a
              href="/contacto"
              class="group border-secondary text-secondary hover:bg-secondary/10 inline-flex items-center justify-center gap-2 rounded-xl border-2 px-6 py-3.5 font-bold transition-all duration-300 hover:scale-105 active:scale-95"
            >
              <span class="text-base font-semibold">Inscribirme ahora</span>
              <ArrowAnimation class="size-5" />
            </a>
          </div>

        </div>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════════
      BANNER — Condiciones de la promo
      Tres píldoras: documentos requeridos, fechas, quién aplica
      ═══════════════════════════════════════════════════════ */}
  <div class="border-y border-primary/10 bg-zinc-950/90 backdrop-blur-sm">
    <div class="mx-auto max-w-5xl px-4 py-5">
      <div
        class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center sm:gap-8 md:gap-14"
      >
        {
          condiciones.map((c, i) => (
            <>
              {/* Píldora de condición */}
              <div class="flex items-center gap-2.5">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-amber-400/10">
                  <span class="text-sm">{c.emoji}</span>
                </div>
                <p class="text-sm text-zinc-400">
                  {c.texto}{" "}
                  <span class="font-semibold text-white">{c.destacado}</span>
                </p>
              </div>

              {/* Separador vertical entre píldoras (solo desktop, no después del último) */}
              {i < condiciones.length - 1 && (
                <div class="hidden h-5 w-px bg-zinc-700 sm:block" />
              )}
            </>
          ))
        }
      </div>
    </div>
  </div>

  {/* ═══════════════════════════════════════════════════════
      SECCIÓN 2 — PLANES CON 20 % OFF
      Tarjetas con imagen de cabecera, precios comparados,
      lista de beneficios y CTA individual por plan
      ═══════════════════════════════════════════════════════ */}
  <SectionContainer class="py-20 md:py-28">
    <div id="planes-papa" class="mx-auto max-w-7xl">

      {/* Encabezado de sección */}
      <div class="mb-14 text-center">
        <span
          class="border-primary/30 bg-primary/10 text-primary mb-4 inline-block rounded-full border px-4 py-1 text-xs font-semibold tracking-widest uppercase"
        >
          Promo del Mes
        </span>
        <h2 class="text-3xl font-black text-white md:text-5xl">
          Tu Mensualidad con{" "}
          <span class="text-primary">20 % Off</span>
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-zinc-400">
          Elige el área que más te guste. Ambas promos incluyen inscripción gratis
          y un mes completo de entrenamiento al mejor precio.
        </p>
      </div>

      {/* Countdown hasta el 30 de junio */}
      <div class="mb-12 flex justify-center">
        <div
          class="border-primary/20 bg-zinc-900/60 rounded-2xl border px-8 py-5 backdrop-blur-sm"
        >
          <p
            class="text-primary mb-4 text-center text-xs font-semibold tracking-widest uppercase"
          >
            Tiempo restante de la promo
          </p>
          <CountdownTimer client:load targetDate="2026-06-30T23:59:59" />
        </div>
      </div>

      {/* Tarjetas de plan */}
      <div class="mx-auto grid max-w-4xl gap-6 md:grid-cols-2">
        {
          promosJunio.map((plan) => (
            <article
              class:list={[
                "group relative flex flex-col overflow-hidden rounded-3xl border backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl",
                plan.highlight
                  ? "border-primary bg-zinc-900/80 hover:shadow-primary/20"
                  : "border-zinc-700/60 bg-zinc-900/60 hover:border-primary/50 hover:shadow-primary/10",
              ]}
            >

              {/* Imagen del área del gym con overlay degradado */}
              <div class="relative h-44 w-full overflow-hidden">
                <img
                  src={plan.imagen}
                  alt={plan.servicio}
                  class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                  loading="lazy"
                />
                {/* Degradado que funde la imagen con el cuerpo de la tarjeta */}
                <div class="absolute inset-0 bg-linear-to-t from-zinc-900 via-zinc-900/30 to-transparent" />

                {/* Badge "20% OFF" fijo sobre la imagen */}
                <div class="absolute top-4 right-4 z-10">
                  <span class="bg-primary rounded-full px-3 py-1.5 text-xs font-black tracking-widest text-black uppercase shadow-lg">
                    20 % OFF
                  </span>
                </div>

                {/* Icono del servicio en la esquina inferior izquierda */}
                <div class="absolute bottom-3 left-5 z-10">
                  <span class="text-2xl drop-shadow-lg">{plan.icon}</span>
                </div>
              </div>

              {/* Cuerpo de la tarjeta */}
              <div class="flex flex-1 flex-col p-7">

                {/* Nombre y subtítulo del servicio */}
                <h3 class="mb-1 text-2xl font-black text-white">{plan.servicio}</h3>
                <p class="text-primary mb-5 text-sm font-semibold">{plan.subtitulo}</p>

                {/* Comparación de precios: tachado + nuevo */}
                <div class="mb-1 flex items-baseline gap-3">
                  <span class="text-lg text-zinc-500 line-through">{plan.precioOriginal}</span>
                  <span
                    class:list={[
                      "text-5xl font-black tabular-nums",
                      plan.highlight ? "text-primary" : "text-white",
                    ]}
                  >
                    {plan.precioPromo}
                  </span>
                </div>
                <p class="mb-4 text-sm text-zinc-500">por persona / mes</p>

                {/* Pill de ahorro */}
                <div class="border-primary/30 bg-primary/10 mb-6 inline-flex w-fit items-center gap-1.5 rounded-full border px-3 py-1">
                  <span class="text-primary text-xs font-bold">
                    ✦ Ahorras {plan.ahorro} este mes
                  </span>
                </div>

                {/* Separador punteado */}
                <div class="border-primary/20 mb-6 border-t border-dashed" />

                {/* Lista de beneficios */}
                <ul class="mb-8 flex-1 space-y-3">
                  {plan.features.map((feature) => (
                    <li class="flex items-center gap-3">
                      <svg
                        class="text-primary h-4 w-4 shrink-0"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                        aria-hidden="true"
                      >
                        <path
                          fill-rule="evenodd"
                          d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                          clip-rule="evenodd"
                        />
                      </svg>
                      <span class="text-sm text-zinc-300">{feature}</span>
                    </li>
                  ))}
                </ul>

                {/* CTA de la tarjeta */}
                <a
                  href="/contacto"
                  class:list={[
                    "block w-full rounded-xl py-3.5 text-center text-sm font-bold transition-all duration-300 hover:scale-[1.02]",
                    plan.highlight
                      ? "bg-primary text-black hover:bg-[#c5eb00]"
                      : "border-primary/50 text-primary border bg-primary/10 hover:bg-primary/20",
                  ]}
                >
                  Inscribirme con este plan
                </a>
              </div>
            </article>
          ))
        }
      </div>

      {/* Nota legal / condiciones resumidas */}
      <p class="mt-8 text-center text-xs text-zinc-600">
