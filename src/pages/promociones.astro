// ═══════════════════════════════════════════════════════════════
//  PROMO TEMPORAL — Día del Padre · Junio 2026
//  20 % de descuento en mensualidades de Pesas y Spinning
//  Precios base: Pesas $380 / Spinning $500
//  Precios promo: Pesas $304 ($380 × 0.80) / Spinning $400 ($500 × 0.80)
//  Solo para papás con identificación oficial · Válido 1–30 junio 2026
// ═══════════════════════════════════════════════════════════════
const promosJunio = [
  {
    id: 1,
    servicio: "Fuerza y Pesas",
    subtitulo: "Área completa con asesoría",
    precioOriginal: "$380",
    precioPromo: "$304",   // $380 × 0.80
    ahorro: "$76",         // $380 × 0.20
    icon: "🏋️",
    imagen: "/bento-info/bentopesas.webp",
    highlight: false,
    features: [
      "Asesoría personalizada en rutinas",
      "Acceso completo al área",
      "Lun–Vie 5am–10pm",
      "Sáb 6:00am–5pm",
