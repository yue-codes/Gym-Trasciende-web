---
/**
 * Área de Adultos Mayores - Página del servicio
 * Diseño minimalista card-first approach
 *
 * ESTRUCTURA:
 * 1. Hero con HeroClipped (imagen de fondo)
 * 2. InfoSlider - ¿Por qué entrenar con nosotros?
 * 3. TrustMetrics - Métricas de confianza
 * 4. Horarios - ScheduleSection
 * 5. Precios - PricingPlan
 * 6. CTA Final
 */

import Layout from "@layouts/Layout.astro";
import HeroClipped from "@components/sections/HeroClipped.astro";
import SectionContainer from "@components/layout/SectionContainer.astro";
import TrustMetrics from "@components/sections/TrustMetrics.astro";
import InfoSlider from "@components/services/InfoSlider.tsx";
import Subtitle from "@components/ui/Subtitle.astro";
import ScheduleSection from "@components/sections/ScheduleSection.astro";
import PricingPlan from "@components/sections/PricingPlan.astro";
import ButtonAnimation from "@components/icons/ButtonAnimation.astro";
import ArrowAnimation from "@components/icons/ArrowAnimation.astro";
import MobileBottomNav from "@components/layout/MobileBottomNav.tsx";
import Gallery from "@components/sections/Gallery.astro";
import ServiceCTA from "@components/sections/ServiceCTA.astro";
import { areaAdultosSlides } from "../../data/services";
import { servicePageNavItems } from "../../data/navigation";

const infoSlides = areaAdultosSlides;

// Horarios para adultos mayores
const schedule = [
  { days: "Lunes a Viernes", hours: "8:00 AM - 12:00 PM" },
  { days: "Sábado", hours: "9:00 AM - 11:00 AM" },
];

const mobileNavItems = servicePageNavItems;

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Área de Adultos Mayores",
  description:
    "Programa de ejercicio seguro y adaptado para adultos mayores en Gym Trasciende Ocotlán. Mejora tu movilidad, equilibrio y bienestar general con supervisión profesional.",
  provider: {
    "@type": "ExerciseGym",
    name: "Gym Trasciende",
    url: "https://trasciendegym.com",
    address: {
      "@type": "PostalAddress",
      streetAddress: "Guillermo Prieto Sur 45, La Estación",
      addressLocality: "Ocotlán de Morelos",
      addressRegion: "Oaxaca",
      postalCode: "71510",
      addressCountry: "MX",
    },
  },
  serviceType: "Ejercicio adaptado para adultos mayores",
  areaServed: { "@type": "City", name: "Ocotlán de Morelos" },
  url: "https://trasciendegym.com/servicios/area-adultos",
};
---

<Layout
  title="Área de Adultos Mayores | Gym Trasciende - Salud y Bienestar"
  description="Mejora tu salud y movilidad en Trasciende Gym Ocotlán. Ejercicio seguro para adultos mayores con atención personalizada. ¡Siéntete vital y fuerte!"
  keywords="adultos mayores, tercera edad, movilidad, salud, ejercicios adaptados, prevención caídas, bienestar, socialización, gimnasio seguro"
  type="website"
  schema={schema}
>
  {/* 1. Hero con HeroClipped */}
  <HeroClipped
    img="/bento-info/entrenadores.webp"
    alt="Área de Adultos en Gym Trasciende"
    minHeight="min-h-screen"
    overlayOpacity="70"
  >
    <div class="mx-auto w-full max-w-7xl px-4">
      <div class="flex w-full flex-col gap-8">
        {/* Badge minimalista */}
        <div class="inline-flex items-center gap-2">
          <div class="bg-primary h-px w-12"></div>
          <span
            class="text-primary text-sm font-semibold tracking-widest uppercase"
          >
            Fuerza y Vitalidad para Siempre
          </span>
        </div>

        {/* Título */}
        <h1
          class="text-secondary text-5xl leading-tight font-bold tracking-wide md:text-7xl lg:text-8xl"
          style="view-transition-name: title-area-adultos"
        >
          Área de Adultos
        </h1>

        {/* Subtítulo */}
        <p class="text-secondary max-w-2xl text-lg leading-relaxed md:text-xl">
          Ejercicios adaptados, ambiente social y atención profesional para
          mejorar tu salud y calidad de vida a cualquier edad.
        </p>

        {/* CTAs con estilo Hero.astro */}
        <div class="flex flex-col gap-4 sm:flex-row sm:gap-6">
          <a
            href="/contacto"
            class="group border-primary text-primary hover:bg-primary/50 inline-flex items-center justify-center gap-2 rounded-lg border-2 px-5 py-2.5 font-bold transition-all duration-300 hover:scale-105 active:scale-95"
          >
            <span class="text-base font-semibold">¡Quiero empezar!</span>
            <ButtonAnimation
              width={24}
              height={24}
              class="transition-transform group-hover:scale-110"
            />
          </a>

          <a
            href="#horarios"
            class="group border-secondary text-secondary hover:bg-secondary/50 inline-flex items-center justify-center gap-2 rounded-lg border-2 px-5 py-2.5 font-bold transition-all duration-300 hover:scale-105 active:scale-95"
          >
            <span class="text-base font-semibold">Ver horarios</span>
            <ArrowAnimation class="size-5" />
          </a>
        </div>
      </div>
    </div>
  </HeroClipped>

  {/* 2. ¿Por Qué Entrenar Con Nosotros? - Info Slider */}
  <SectionContainer class="py-20 md:py-32">
    <div class="mx-auto max-w-7xl">
      <Subtitle>¿Por Qué Entrenar Con Nosotros?</Subtitle>
      <InfoSlider client:visible slides={infoSlides} />
    </div>
  </SectionContainer>

  {/* 3. Métricas de confianza */}
  <TrustMetrics />

  {/* 4. Horarios */}
  <SectionContainer id="horarios" class="py-20 md:py-32">
    <div class="mx-auto max-w-3xl">
      <Subtitle>Horarios Preferentes</Subtitle>
      <p class="text-secondary mb-8 text-center">
        Clases en horarios cómodos con atención personalizada.
      </p>
      <ScheduleSection schedule={schedule} />
      <div class="mt-6 text-center">
        <p class="text-sm text-zinc-400">
          💡 Horarios matutinos ideales para adultos mayores.
        </p>
      </div>
    </div>
  </SectionContainer>

  {/* 5. Precios */}
  <div id="precios">
    <PricingPlan allowedAreas={["area3"]} showSelector={false} />
  </div>

  <Gallery />

  {/* 6. CTA Final */}
  <ServiceCTA
    heading="Vive la Experiencia Única"
    description="Ven a conocernos y entrena en un ambiente amigable donde cada rutina está pensada para tu bienestar y seguridad. ¡Te esperamos!"
    ctaLabel="¡Empieza hoy!"
  />

  {/* Navegación móvil inferior */}
  <MobileBottomNav
    client:load
    items={mobileNavItems}
    hideOnScroll={false}
    vibration={true}
  />
</Layout>
