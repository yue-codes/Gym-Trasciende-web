---
/**
 * Spinning - Página del servicio
 * Diseño minimalista card-first approach
 *
 * ESTRUCTURA:
 * 1. Hero con HeroClipped (imagen de fondo)
 * 2. InfoSlider - ¿Por qué entrenar spinning con nosotros?
 * 3. TrustMetrics - Métricas de confianza
 * 4. Horarios - ScheduleSection
 * 5. Precios - PricingPlan
 * 6. CTA Final
 */

import Layout from "@layouts/Layout.astro";
import HeroClipped from "@components/sections/HeroClipped.astro";
import SectionContainer from "@components/layout/SectionContainer.astro";
import TrustMetrics from "@components/sections/TrustMetrics.astro";
import InfoSlider from "@components/services/InfoSlider.tsx";
import Subtitle from "@components/ui/Subtitle.astro";
import ScheduleSection from "@components/sections/ScheduleSection.astro";
import PricingPlan from "@components/sections/PricingPlan.astro";
import ButtonAnimation from "@components/icons/ButtonAnimation.astro";
import ArrowAnimation from "@components/icons/ArrowAnimation.astro";
import MobileBottomNav from "@components/layout/MobileBottomNav.tsx";
import Gallery from "@components/sections/Gallery.astro";
import ServiceCTA from "@components/sections/ServiceCTA.astro";
import { spinningSlides } from "../../data/services";
import { servicePageNavItems } from "../../data/navigation";

const infoSlides = spinningSlides;

// Horarios de clases de spinning
const schedule = [
  { days: "Lunes a Viernes", hours: "7:00 AM - 8:00 AM" },
  { days: "Lunes a Viernes", hours: "8:00 AM - 9:00 AM" },
  { days: "Lunes a Viernes", hours: "6:00 PM - 7:00 PM" },
  { days: "Lunes a Viernes", hours: "7:00 PM - 8:00 PM" },
];

const mobileNavItems = servicePageNavItems;

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Clases de Spinning",
  description:
    "Clases de spinning para todos los niveles en Gym Trasciende Ocotlán. Quema calorías, mejora tu salud cardiovascular y diviértete al ritmo de la música con instructores certificados.",
  provider: {
    "@type": "ExerciseGym",
    name: "Gym Trasciende",
    url: "https://trasciendegym.com",
    address: {
      "@type": "PostalAddress",
      streetAddress: "Guillermo Prieto Sur 45, La Estación",
      addressLocality: "Ocotlán de Morelos",
      addressRegion: "Oaxaca",
      postalCode: "71510",
      addressCountry: "MX",
    },
  },
  serviceType: "Clases grupales de spinning",
  areaServed: { "@type": "City", name: "Ocotlán de Morelos" },
  url: "https://trasciendegym.com/servicios/spinning",
};
---

<Layout
  title="Clases de Spinning | Gym Trasciende - Quema Calorías y Diviértete"
  description="¡Quema calorías con las mejores clases de spinning en Ocotlán! En Trasciende Gym tenemos el mejor ambiente y horarios desde las 5 am. ¡Reserva tu lugar hoy!"
  keywords="clases spinning, spinning gym, entrenamiento cardiovascular, quemar calorías, clases grupales fitness, spinning para principiantes, instructores spinning certificados"
  type="website"
  schema={schema}
>
  {/* 1. Hero con HeroClipped */}
  <HeroClipped
    img="/bento-info/bentospining.webp"
    alt="Clases de Spinning en Gym Trasciende"
    minHeight="min-h-screen"
    overlayOpacity="70"
  >
    <div class="mx-auto w-full max-w-7xl px-4">
      <div class="flex w-full flex-col gap-8">
        {/* Badge minimalista */}
        <div class="inline-flex items-center gap-2">
          <div class="bg-primary h-px w-12"></div>
          <span
            class="text-primary text-sm font-semibold tracking-widest uppercase"
          >
            Entrenamiento Cardiovascular
          </span>
        </div>

        {/* Título */}
        <h1
          class="text-secondary text-5xl leading-tight font-bold tracking-wide md:text-7xl lg:text-8xl"
          style="view-transition-name: title-spinning"
        >
          Clases de Spinning
        </h1>

        {/* Subtítulo */}
        <p class="text-secondary max-w-2xl text-lg leading-relaxed md:text-xl">
          Quema calorías, fortalece tu corazón y diviértete al ritmo de la
          música con nuestras clases profesionales de spinning.
        </p>

        {/* CTAs con estilo Hero.astro */}
        <div class="flex flex-col gap-4 sm:flex-row sm:gap-6">
          <a
            href="/contacto"
            class="group border-primary text-primary hover:bg-primary/50 inline-flex items-center justify-center gap-2 rounded-lg border-2 px-5 py-2.5 font-bold transition-all duration-300 hover:scale-105 active:scale-95"
          >
            <span class="text-base font-semibold">¡Reserva tu clase!</span>
            <ButtonAnimation
              width={24}
              height={24}
              class="transition-transform group-hover:scale-110"
            />
          </a>

          <a
            href="#horarios"
            class="group border-secondary text-secondary hover:bg-secondary/50 inline-flex items-center justify-center gap-2 rounded-lg border-2 px-5 py-2.5 font-bold transition-all duration-300 hover:scale-105 active:scale-95"
          >
            <span class="text-base font-semibold">Ver horarios</span>
            <ArrowAnimation class="size-5" />
          </a>
        </div>
      </div>
    </div>
  </HeroClipped>

  {/* 2. ¿Por Qué Entrenar Spinning Con Nosotros? - Info Slider */}
  <SectionContainer class="py-20 md:py-32">
    <div class="mx-auto max-w-7xl">
      <Subtitle>¿Por Qué Entrenar Spinning Con Nosotros?</Subtitle>
      <InfoSlider client:visible slides={infoSlides} />
    </div>
  </SectionContainer>

  {/* 3. Métricas de confianza */}
  <TrustMetrics />

  {/* 4. Horarios */}
  <SectionContainer id="horarios" class="py-20 md:py-32">
    <div class="mx-auto max-w-3xl">
      <Subtitle>Horarios de Clases</Subtitle>
      <p class="text-secondary mb-8 text-center">
        Reserva tu lugar con anticipación. Cupo limitado.
      </p>
      <ScheduleSection schedule={schedule} />
      <div class="mt-6 text-center">
        <p class="text-sm text-zinc-400">
          💡 Tip: Las clases de 7:00 AM y 7:00 PM son las más populares.
        </p>
      </div>
    </div>
  </SectionContainer>

  {/* 5. Precios */}
  <div id="precios">
    <PricingPlan allowedAreas={["area1"]} showSelector={false} />
  </div>

  <Gallery />

  {/* 6. CTA Final */}
  <ServiceCTA
    heading="Vive la Experiencia Spinning"
    description="Más que un entrenamiento, es el momento de conectar contigo mismo. Únete a nuestra comunidad y descubre por qué somos la mejor motivación para tu día."
    ctaLabel="¡Reserva tu clase!"
  />

  {/* Navegación móvil inferior */}
  <MobileBottomNav
    client:load
    items={mobileNavItems}
    hideOnScroll={false}
    vibration={true}
  />
</Layout>
