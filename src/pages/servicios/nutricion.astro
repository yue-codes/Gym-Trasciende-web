---
/**
 * Nutrición - Página rediseñada con identidad de Yanely García
 *
 * ESTRUCTURA:
 * 1. Hero Split-Screen (Yanely García)
 * 2. Benefit Cards — ¿Qué es la Asesoría Nutricional?
 * 3. Perfil de la Nutrióloga
 * 4. Cupones de Descuento (10% miembros / 20% asesorados)
 * 5. TrustMetrics
 * 6. Horarios + Contacto directo
 * 7. Precios
 * 8. CTA Final
 */

import Layout from "@layouts/Layout.astro";
import SectionContainer from "@components/layout/SectionContainer.astro";
import TrustMetrics from "@components/sections/TrustMetrics.astro";
import ScheduleSection from "@components/sections/ScheduleSection.astro";
import PricingPlan from "@components/sections/PricingPlan.astro";
import MobileBottomNav from "@components/layout/MobileBottomNav.tsx";

// Horarios de asesorías nutricionales
const schedule = [
  { days: "Lunes a Viernes", hours: "8:00 AM - 10:00 PM" },
  { days: "Sábado", hours: "8:00 AM - 2:00 PM" },
];

// Configuración de navegación móvil
const mobileNavItems = [
  {
    id: "cupones",
    label: "Cupones",
    href: "#descuentos",
    icon: "tag" as const,
  },
  {
    id: "nutri",
    label: "Tu Nutri",
    href: "#nutri",
    icon: "image" as const,
  },
  {
    id: "contacto",
    label: "Contacto",
    href: "#cta",
    icon: "star" as const,
  },
  { id: "servicios", label: "Más", href: "/servicios", icon: "grid" as const },
];

const whatsappUrl =
  "https://wa.me/529516117406?text=Hola%20Yanely%2C%20me%20interesa%20agendar%20una%20asesor%C3%ADa%20nutricional";

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Asesoría Nutricional con Yanely García",
  description:
    "Asesoría nutricional personalizada con LN. Ed. Yanely García en Trasciende Gym Ocotlán. Planes alimenticios adaptados a tu estilo de vida y objetivos deportivos.",
  provider: {
    "@type": "ExerciseGym",
    name: "Gym Trasciende",
    url: "https://trasciendegym.com",
    address: {
      "@type": "PostalAddress",
      streetAddress: "Guillermo Prieto Sur 45, La Estación",
      addressLocality: "Ocotlán de Morelos",
      addressRegion: "Oaxaca",
      postalCode: "71510",
      addressCountry: "MX",
    },
  },
  serviceType: "Asesoría nutricional personalizada",
  areaServed: { "@type": "City", name: "Ocotlán de Morelos" },
  url: "https://trasciendegym.com/servicios/nutricion",
};
---

<Layout
  title="Asesoría Nutricional con Yanely García | Trasciende Gym Ocotlán"
  description="Asesoría nutricional personalizada con LN. Ed. Yanely García en Trasciende Gym Ocotlán. Mejora tu rendimiento deportivo con nutrición profesional. 10–20% descuento para miembros."
  keywords="nutrióloga ocotlán, asesoría nutricional, Yanely García, nutrición deportiva, plan alimenticio personalizado, descuento nutrición gym trasciende"
  type="website"
  schema={schema}
>
  {
    /* ═══════════════════════════════════════════════════════════════
      SECCIÓN 1 — HERO SPLIT-SCREEN
      ═══════════════════════════════════════════════════════════════ */
  }
  <section
    class="bg-background relative min-h-screen overflow-hidden"
    aria-label="Asesoría Nutricional con Yanely García"
  >
    {/* ── MOBILE ONLY: imagen cubre los ~70% superiores del hero ── */}
    <div class="absolute inset-x-0 top-0 h-[72%] lg:hidden" aria-hidden="true">
      <img
        src="/nutri.webp"
        alt=""
        class="h-full w-full object-cover object-top"
        loading="eager"
      />
      {/* Tinte verde olivo sobre la foto */}
      <div
        class="to-nutri/10 absolute inset-0 bg-linear-to-br from-[#2d3d10]/70 via-[#4a6020]/40"
      >
      </div>
      {
        /* Degradado full-height: transparent arriba → background abajo, sin línea */
      }
      <div
        class="from-background via-background/70 absolute inset-0 bg-linear-to-t from-15% via-55% to-transparent"
      >
      </div>
