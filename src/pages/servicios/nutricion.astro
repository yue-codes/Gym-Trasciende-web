    >
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-4 lg:py-0">
      <div class="flex min-h-screen flex-col lg:flex-row">
        {/* ── Columna Izquierda: Texto ── */}
        {/* Mobile: overlay en la parte inferior. Desktop: columna izquierda */}
        <div
          class="mt-auto flex w-full flex-col justify-end gap-5 pb-10 lg:mt-0 lg:w-1/2 lg:justify-center lg:gap-6 lg:py-24 lg:pr-16"
        >
          {/* Badge */}
          <div class="inline-flex items-center gap-3">
            <span
              class="border-nutri/40 bg-nutri/10 text-nutri rounded-full border px-4 py-1.5 text-xs font-semibold tracking-widest uppercase"
            >
              Asesoría Nutricional · Trasciende Gym
            </span>
          </div>

          {/* Título */}
          <h1
            class="text-4xl leading-[1.05] font-black tracking-tight text-white sm:text-5xl md:text-6xl lg:text-7xl"
            style="view-transition-name: title-nutricion"
          >
            Asesoría
            <span
              class="to-primary from-nutri block bg-linear-to-r bg-clip-text text-transparent"
            >
              Nutricional
            </span>
          </h1>

          {/* Eslogan */}
          <p class="max-w-lg text-lg leading-relaxed text-zinc-300 md:text-xl">
            &ldquo;Incrementa tu rendimiento en el entrenamiento de fuerza con
            la guía y orientación profesional&rdquo;
          </p>

          {/* Nombre y credencial */}
          <div class="flex items-center gap-3">
            <div class="bg-nutri h-px w-10"></div>
            <p class="text-nutri text-sm font-semibold tracking-wide uppercase">
              LN. Ed. Yanely García · Nutrióloga
            </p>
          </div>

          {/* Info de contacto */}
          <ul class="space-y-2.5">
            <li class="flex items-center gap-3 text-zinc-300">
              <span
                class="bg-nutri/15 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg text-base"
              >
                📱
              </span>
              <span class="text-sm font-medium"
                >WhatsApp: <strong class="text-white">951 611 7406</strong
                ></span
              >
            </li>
            <li class="flex items-center gap-3 text-zinc-300">
              <span
                class="bg-nutri/15 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg text-base"
              >
                📍
              </span>
              <span class="text-sm font-medium"
                >Ocotlán de Morelos <span class="text-zinc-500">·</span> Online</span
              >
            </li>
            <li class="flex items-center gap-3 text-zinc-300">
              <span
                class="bg-nutri/15 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg text-base"
              >
                📸
              </span>
              <a
                href="https://instagram.com/nutriologayanely"
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-nutri text-sm font-medium transition-colors"
                >@nutriologayanely</a
              >
            </li>
          </ul>

          {/* CTAs */}
          <div class="flex flex-col gap-3 pt-2 sm:flex-row">
            <a
              href={whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="group bg-cta-orange shadow-cta-orange/20 hover:shadow-cta-orange/40 inline-flex items-center justify-center gap-2 rounded-xl px-7 py-3.5 text-base font-bold text-white shadow-lg transition-all duration-300 hover:scale-105 hover:bg-[#e07d20] active:scale-95"
            >
              <svg
                class="h-5 w-5"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
