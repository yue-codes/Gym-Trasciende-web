  <SectionContainer class="py-20 md:py-28">
    <div class="mx-auto max-w-7xl">
      {/* Header */}
      <div class="mb-14 text-center">
        <span
          class="border-nutri/30 bg-nutri/10 text-nutri mb-4 inline-block rounded-full border px-4 py-1 text-xs font-semibold tracking-widest uppercase"
